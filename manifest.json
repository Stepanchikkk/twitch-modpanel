{
  "manifest_version": 3,
  "name": "Twitch ModPanel",
  "version": "1.0.0",
  "description": "Панель модератора для Twitch — быстрый доступ к инструментам управления стримом",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://api.twitch.tv/*",
    "https://id.twitch.tv/*",
    "https://*.twitch.tv/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["twitch-api.js", "icons/icon128.png", "icons/icon-*.svg"],
      "matches": ["https://*.twitch.tv/*"]
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*.twitch.tv/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "type": "module"
    }
  ],
  "icons": {
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "128": "icons/icon128.png"
    },
    "default_title": "Twitch ModPanel"
  }
}
